# Supabase — copy this file to .env.local and fill in your project's values.
# Find these in the Supabase dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret (NEVER expose to the browser / never prefix with NEXT_PUBLIC).
# Only needed if you use admin/service operations from server code.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — https://dashboard.stripe.com/test/apikeys (use TEST keys for development).
# Publishable key is safe in the browser; secret key is server-only, never commit.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from the Stripe CLI `stripe listen`, added when wiring the webhook
